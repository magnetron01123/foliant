# Gateway vor foliant (MCP) + web (Charakterbogen). Der Cloudflare-Tunnel zeigt nach dem
# Umschalten auf http://gateway:8080. AUFTRAG §5.2:
#  - Admin-API aus, KEINE Access-Logs (der MCP-Pfad enthaelt das Geheim-Token).
#  - /mcp + /<ein-Segment>/mcp[/...] -> foliant (unveraendert, Streaming, kein Buffering).
#  - /health, /ready -> foliant (Tunnel-/Container-Healthcheck bleibt echt).
#  - alles andere -> web (Website).
#  - Falscher Token-Pfad landet bei foliant und bekommt dort 403/404, NIE Website-HTML.

{
	admin off
	auto_https off
	log {
		output discard
	}
}

:8080 {
	log {
		output discard
	}

	# MCP: /mcp, /mcp/*, /<token>/mcp, /<token>/mcp/* -> foliant (Token bleibt geheim,
	# Caddy prueft ihn NICHT; foliant/ZugriffsFilter entscheidet 403/404 wie bisher).
	@mcp path /mcp /mcp/* /*/mcp /*/mcp/*
	handle @mcp {
		reverse_proxy foliant:8000 {
			flush_interval -1
		}
	}

	# Health/Readiness unveraendert an foliant.
	@foliant_health path /health /ready
	handle @foliant_health {
		reverse_proxy foliant:8000
	}

	# Alles Uebrige -> Website, hinter Passwortschutz. Die Website selbst ist authlos und JEDE
	# Konvertierung kostet Anthropic-API-Geld -> ohne Schranke waere sie ein offenes Portemonnaie
	# (der Hostname steht ueber Certificate-Transparency-Logs oeffentlich; Scanner finden ihn).
	# handle-Bloecke sind EXKLUSIV: @mcp und /health sind oben abgehandelt und sehen basic_auth NIE.
	# Zugangsdaten ausschliesslich aus der Pi-.env (WEB_BENUTZER/WEB_HASH) - nie ins oeffentliche Repo.
	handle {
		basic_auth {
			{$WEB_BENUTZER} {$WEB_HASH}
		}
		reverse_proxy web:8080
	}
}
