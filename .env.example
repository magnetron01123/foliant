# Foliant - Umgebungsvariablen. Kopieren nach .env (gitignored). KEINE echten Werte committen.

# Cloudflare Named Tunnel Token (aus dem Zero-Trust-Dashboard):
CLOUDFLARE_TUNNEL_TOKEN=

# HINWEIS: Das DDB-Cobalt-Secret gehoert NICHT hierher. Der DDB-Exporter fragt es zur
# Laufzeit verdeckt ueber die TTY ab (nie .env, argv, Compose-Environment oder Logs) -
# siehe docs/ddb-architektur-entscheidung.md.

# Zugang (M3, app/zugriff.py): Geheimpfad-Token - der MCP-Endpoint liegt dann unter
# https://<host>/<token>/mcp (die URL ist der Schluessel). Erzeugen:
#   python3 -c "import secrets; print(secrets.token_urlsafe(18))"
# Rotation bei Leak: neuen Wert setzen, `docker compose up -d --build foliant`, neue URL teilen.
FOLIANT_PFAD_TOKEN=

# IP-Allowlist (Anthropic-Egress, an/aus - 'aus' nur zum Debuggen):
FOLIANT_IP_FILTER=an
# Optionale Zusatz-CIDRs (kommagetrennt), z. B. Heim-IP fuer Direkt-Tests oder Uptime-Monitor:
FOLIANT_ERLAUBTE_IPS=
