{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(rm)",
      "Bash(rm *)",
      "Bash(sudo)",
      "Bash(sudo *)",
      "Bash(git push --all)",
      "Bash(git push --all *)",
      "Bash(git push origin --all)",
      "Bash(git push origin --all *)",
      "Bash(git push --mirror *)",
      "Read(./config/zugriff.toml)",
      "Edit(./config/zugriff.toml)",
      "Write(./config/zugriff.toml)",
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Read(./.env.local)",
      "Edit(./.env.local)",
      "Write(./.env.local)",
      "Read(./**/.env)",
      "Edit(./**/.env)",
      "Write(./**/.env)",
      "Read(./secrets/**)",
      "Edit(./secrets/**)",
      "Write(./secrets/**)",
      "Read(./*.sqlite)",
      "Read(./**/*.sqlite)",
      "Read(./**/*.sqlite-*)",
      "Read(./*.db)",
      "Read(./**/*.db)",
      "Edit(./*.sqlite)",
      "Edit(./**/*.sqlite)",
      "Edit(./**/*.sqlite-*)",
      "Edit(./*.db)",
      "Edit(./**/*.db)",
      "Write(./*.sqlite)",
      "Write(./**/*.sqlite)",
      "Write(./**/*.sqlite-*)",
      "Write(./*.db)",
      "Write(./**/*.db)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(gh pr merge)",
      "Bash(gh pr merge *)"
    ],
    "allow": [
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(.venv/bin/python *)",
      "Bash(.venv/bin/python3 *)",
      "Bash(.venv-ddb/bin/python *)",
      "Bash(.venv-ddb/bin/python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(.venv/bin/pip *)",
      "Bash(.venv-ddb/bin/pip *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(pytest *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(.venv-ddb/bin/pytest *)",
      "Bash(make *)",
      "Bash(ruff *)",
      "Bash(.venv/bin/ruff *)",
      "Bash(mypy *)",
      "Bash(.venv/bin/mypy *)",
      "Bash(black *)",
      "Bash(.venv/bin/black *)",

      "Bash(sqlite3 -readonly *)",
      "Bash(datasette *)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git config *)",
      "Bash(git --version)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git checkout)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git worktree *)",
      "Bash(git bundle *)",

      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr diff *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(gh issue *)",

      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(curl *)",
      "Bash(wget *)",

      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(chmod *)",
      "Bash(unzip *)"
    ]
  }
}
